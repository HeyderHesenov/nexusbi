# ─── AI Provider ───
# API key + engine identity for the AI layer. Set both in your local .env.
OPENAI_API_KEY=
OPENAI_MODEL=
# Embedding model for RAG grounding (empty key => deterministic offline fallback).
EMBEDDING_MODEL=text-embedding-3-small

# ─── RAG / vector grounding (portable: SQLite + numpy cosine) ───
RAG_ENABLED=true
RAG_TOP_K=5                 # similar examples injected into the Text2SQL prompt
RAG_MAX_CANDIDATES=200      # rows scored per retrieval (bounds cost)
RAG_HASH_DIM=256            # dim of the keyless/offline hash embedding
RAG_INDEX_ON_WRITE=true     # embed each fresh NL→SQL pair

# ─── AI eval & observability ───
AI_TRACE_ENABLED=true       # in-process rolling token/latency trace for the AI Quality view
EVAL_MIN_ACCURACY=0.5       # golden-set exec-accuracy floor (notes a run as below-threshold)

# ─── Google Sign-In (optional) ───
# Google Cloud → APIs & Services → Credentials → OAuth client ID (Web).
# Empty = Google button shows a "not configured" message.
GOOGLE_CLIENT_ID=

# ─── Database ───
# Demo/dev: SQLite. Prod: postgresql+asyncpg://user:pass@db:5432/nexusbi
DATABASE_URL=sqlite+aiosqlite:///./nexusbi.db
# App-DB connection pool (ignored for SQLite).
APP_DB_POOL_SIZE=10
APP_DB_POOL_MAX_OVERFLOW=20
APP_DB_POOL_RECYCLE_SECONDS=1800

# ─── Redis (optional in demo) ───
# Query-result cache + schema cache. Without Redis the app degrades gracefully.
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300
SQLGEN_CACHE_TTL_SECONDS=900
# Hard cap on a single SELECT (Postgres/MySQL statement timeout).
QUERY_TIMEOUT_SECONDS=15

# ─── Datasource connection pooling ───
DATASOURCE_POOL_SIZE=5
DATASOURCE_POOL_MAX_OVERFLOW=10
DATASOURCE_POOL_RECYCLE_SECONDS=1800
DATASOURCE_MAX_ENGINES=20

# ─── CSV/Excel uploads (file-backed datasources) ───
UPLOAD_DIR=./data/uploads
UPLOAD_MAX_BYTES=10485760

# ─── Saved-query scheduler (in-process) ───
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=60

# ─── Proactive AI digest (morning brief) ───
DIGEST_ENABLED=true
DIGEST_HOUR_UTC=6
DIGEST_MAX_ITEMS=5

# ─── Live dashboards (real-time refresh + collab WS) ───
LIVE_REFRESH_ENABLED=true
LIVE_REFRESH_TICK_SECONDS=4
LIVE_DEMO_FEED=true

# ─── Agentic copilot ───
COPILOT_MAX_STEPS=8

# ─── Power BI (optional; empty = mock provider, no license needed) ───
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_API_BASE=https://api.powerbi.com/v1.0/myorg
POWERBI_MAX_ROWS=10000

# ─── Workflow integrations (Slack/Teams/email) — mock-first ───
# INTEGRATIONS_LIVE=false → deliveries are logged (no outbound calls).
INTEGRATIONS_LIVE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=nexusbi@example.com

# ─── Stripe billing (config-gated; empty = mock /upgrade only) ───
STRIPE_SECRET_KEY=
STRIPE_SUCCESS_URL=http://localhost:5173/pricing?paid=1
STRIPE_CANCEL_URL=http://localhost:5173/pricing

# ─── Security ───
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
# Fernet key for encrypting datasource connection strings
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# Bearer token to gate /metrics in prod (empty => loopback-only).
METRICS_TOKEN=

# ─── App ───
DEMO_MODE=true
CORS_ORIGINS=http://localhost:5173
